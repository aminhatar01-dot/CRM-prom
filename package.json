{
  "name": "crm-pro-ai",
  "version": "0.1.0",
  "private": true,
  "description": "CRM PRO AI SaaS monorepo",
  "scripts": {
    "dev": "npm run dev --workspace @crm-pro-ai/web",
    "build": "npm run build --workspaces --if-present",
    "lint": "eslint apps/web/src apps/web/tests packages scripts --max-warnings=0",
    "test": "vitest run",
    "validate": "npm run lint && npm run build && npm run test",
    "predeploy": "npm run deploy:check && npm run validate",
    "deploy:check": "node scripts/deploy-check.mjs all",
    "env:check": "node scripts/deploy-check.mjs env",
    "db:check": "node scripts/deploy-check.mjs db",
    "app:check": "node scripts/deploy-check.mjs app --build",
    "qa:smoke": "playwright test --config apps/web/playwright.config.ts --grep @smoke",
    "qa:e2e": "vitest run apps/web/tests/qa/mvp-full-flow.test.ts && playwright test --config apps/web/playwright.config.ts",
    "qa:functional": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/phase14-functional-local.ps1",
    "qa:functional:remote": "playwright test --config apps/web/phase14.playwright.config.ts",
    "qa:pipeline": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/phase14-functional-local.ps1 -PlaywrightConfig apps/web/phase15.playwright.config.ts",
    "db:push": "npx supabase db push",
    "db:seed": "npx supabase db reset --local",
    "db:seed:remote": "npx supabase db push --linked --include-seed --yes",
    "db:test:phase13": "node scripts/test-phase13-db.mjs",
    "format": "prettier . --write",
    "typecheck": "tsc --build --pretty"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.29.0",
    "@playwright/test": "^1.53.0",
    "@types/node": "^22.15.31",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.29.0",
    "eslint-config-next": "^15.3.3",
    "eslint-config-prettier": "^10.1.5",
    "prettier": "^3.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vitest": "^3.2.3"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@hookform/resolvers": "^5.1.1",
    "@radix-ui/react-slot": "^1.2.3",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.50.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "next": "^15.3.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.58.1",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.25.64"
  }
}
